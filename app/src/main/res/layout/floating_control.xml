<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/slider_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_glass" 
    android:padding="8dp" android:gravity="center"
    android:elevation="6dp">

    <Button
        android:id="@+id/btn_vol_up"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="+"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Volume Up" />

    <View
        android:layout_width="24dp"
        android:layout_height="1dp"
        android:layout_marginVertical="2dp"
        android:background="#44FFFFFF" />

    <Button
        android:id="@+id/btn_vol_down"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="−"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Volume Down" />

</LinearLayout>