<?xml version="1.0" encoding="utf-8"?>
<com.example.volumeslider.DraggableLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/slider_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:elevation="8dp">

    <!--
        PEEK TAB — visible when collapsed.
        A slim pill that peeks from the screen edge.
        The open side faces the edge so it looks flush with the screen.
    -->
    <FrameLayout
        android:id="@+id/peek_tab"
        android:layout_width="14dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_peek_tab"
        android:visibility="gone"/>

    <!--
        MENU PANEL — visible when expanded.
        Contains vol up, vol down, and mute.
        Open edge faces the screen edge, rounded on the other side.
    -->
    <LinearLayout
        android:id="@+id/menu_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_glass"
        android:padding="10dp"
        android:gravity="center"
        android:visibility="visible">

        <ImageButton
            android:id="@+id/btn_vol_up"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_vol_up"
            android:background="@drawable/bg_circle_button"
            android:contentDescription="Volume Up"
            android:scaleType="center"/>

        <View
            android:layout_width="36dp"
            android:layout_height="1dp"
            android:layout_marginVertical="4dp"
            android:background="#33FFFFFF"/>

        <ImageButton
            android:id="@+id/btn_vol_down"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_vol_down"
            android:background="@drawable/bg_circle_button"
            android:contentDescription="Volume Down"
            android:scaleType="center"/>

        <View
            android:layout_width="36dp"
            android:layout_height="1dp"
            android:layout_marginVertical="4dp"
            android:background="#33FFFFFF"/>

        <Button
            android:id="@+id/btn_mute"
            android:layout_width="56dp"
            android:layout_height="28dp"
            android:text="MUTE"
            android:textSize="10sp"
            android:textColor="#AAAAAA"
            android:letterSpacing="0.08"
            android:background="@drawable/bg_mute_button"
            android:contentDescription="Mute"/>

    </LinearLayout>

</com.example.volumeslider.DraggableLayout>