<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ── Header ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volume Slider"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="32dp"/>

        <!-- ── Card: Overlay toggle ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OVERLAY"
                android:textColor="#666666"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="16dp"/>

            <!-- Toggle row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Show floating button"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Display the volume control overlay"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_overlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:thumbTint="#FFFFFF"
                    android:trackTint="#444444"/>

            </LinearLayout>
        </LinearLayout>

        <!-- ── Card: Widget size ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPEARANCE"
                android:textColor="#666666"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="16dp"/>

            <!-- Widget size row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Button size"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/label_widget_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="56dp"
                    android:textColor="#888888"
                    android:textSize="14sp"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbar_widget_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:min="44"
                android:max="80"
                android:progress="56"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF"
                android:layout_marginBottom="24dp"/>

            <!-- Peek width row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Peek width when hidden"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/label_peek_width"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="32dp"
                    android:textColor="#888888"
                    android:textSize="14sp"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbar_peek_width"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:min="16"
                android:max="56"
                android:progress="32"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF"/>

        </LinearLayout>

        <!-- ── Footer note ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Changes apply immediately while the overlay is running."
            android:textColor="#555555"
            android:textSize="12sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>