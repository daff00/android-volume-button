<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Lighter base: dark grey at 85% opacity. Visible on both dark
         wallpapers AND light wallpapers. #222 instead of #000 gives
         the frosted-glass look without disappearing on dark backgrounds. -->
    <solid android:color="#D9222222" />
    <corners android:radius="28dp" />
    <!-- Brighter border: 55% white instead of 20%. Creates a clear
         halo that separates the widget from any background. -->
    <stroke android:width="1.5dp" android:color="#8CFFFFFF"/>
</shape>